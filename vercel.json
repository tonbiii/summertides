{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://summer.globalcryptotransfer.com/api/:path*"
    },
    {
      "source": "/refer/:path*",
      "destination": "https://summer.globalcryptotransfer.com/refer/:path*"
    },
    {
      "source": "/refer",
      "destination": "https://summer.globalcryptotransfer.com/refer"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
